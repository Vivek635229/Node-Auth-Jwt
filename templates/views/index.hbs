<!DOCTYPE html>
<html lang="en">
<head>
    <title>NodeAuth - JWT Authentication</title>
    {{>header}}
</head>
<body>
    <div class="bg-orb orb-left"></div>
    <div class="bg-orb orb-right"></div>

    <header class="header">
        <nav class="navbar">
            <h2 class="logo"><a href="/">NodeAuth</a></h2>
            <input type="checkbox" id="menu-toggle" />
            <label for="menu-toggle" id="hamburger-btn">
                <svg xmlns="http://www.w3.org/2000/svg" height="24" viewBox="0 0 24 24" width="24">
                    <path d="M3 12h18M3 6h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
            </label>

            <ul class="links">
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
            </ul>

            <div class="buttons">
                {{#if isAuthenticated}}
                    <span class="welcome-pill">Welcome, {{username}}</span>
                    <a href="/logout" class="signup">Logout</a>
                {{else}}
                    <a href="/signin" class="signin">Sign In</a>
                    <a href="/signup" class="signup">Sign Up</a>
                {{/if}}
            </div>
        </nav>
    </header>

    <main class="hero-section">
        <div class="hero">
            <p class="kicker">JWT based full-stack authentication</p>
            <h1>Secure login flows with clean UX for your users.</h1>
            <p>
                Sign up, sign in, and recover forgotten passwords through token-based security.
                Your session is protected with HTTP-only cookies and personalized navigation.
            </p>

            <div class="buttons hero-cta">
                {{#if isAuthenticated}}
                    <a href="/about" class="join">Go to Dashboard</a>
                    <a href="/forgot-password" class="learn">Reset Password</a>
                {{else}}
                    <a href="/signup" class="join">Create Account</a>
                    <a href="/signin" class="learn">I Have an Account</a>
                {{/if}}
            </div>

            <div class="status-card">
                <strong>Status:</strong>
                {{#if isAuthenticated}}
                    Logged in as {{username}}
                {{else}}
                    Not logged in
                {{/if}}
            </div>
        </div>

        <div class="img">
            <img src="/images/auth-hero.svg"
                alt="Authentication security concept" />
        </div>
    </main>

    {{>toast}}
</body>
</html>